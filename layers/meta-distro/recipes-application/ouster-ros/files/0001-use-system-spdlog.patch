From: James Cahill <jcahill@ieee.org>
Date: Thu, 21 Apr 2026 11:24:00 +0000
Subject: [PATCH] use system spdlog instead of bundled thirdparty

Use system spdlog instead of including vendored spdlog headers
to avoid loading multiple versions at runtime, which in our case 
caused an ABI mismatch & SIGBUS being thrown when using pattern_formatter::format.

Upstream-Status: Inappropriate [temporary-hacks]

diff --git a/ouster-ros/ouster-sdk/cmake/Findspdlog.cmake b/ouster-ros/ouster-sdk/cmake/Findspdlog.cmake
deleted file mode 100644
index e421124..0000000
--- a/ouster-ros/ouster-sdk/cmake/Findspdlog.cmake
+++ /dev/null
@@ -1,6 +0,0 @@
-# Allow downstream code to depend on source transparently
-if(NOT SPDLOG_INCLUDED)
-  add_custom_target(SPDLOG_INCLUDED)
-  add_subdirectory(${CMAKE_CURRENT_LIST_DIR}/../thirdparty/spdlog
-    ${CMAKE_CURRENT_BINARY_DIR}/spdlog EXCLUDE_FROM_ALL)
-endif()
diff --git a/ouster-ros/ouster-sdk/ouster_client/CMakeLists.txt b/ouster-ros/ouster-sdk/ouster_client/CMakeLists.txt
index f17eeb4..00d983f 100644
--- a/ouster-ros/ouster-sdk/ouster_client/CMakeLists.txt
+++ b/ouster-ros/ouster-sdk/ouster_client/CMakeLists.txt
@@ -70,7 +70,6 @@ target_include_directories(ouster_client
       $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/include>
   PRIVATE
       ${OPENSSL_INCLUDE_DIR}
-      $<BUILD_INTERFACE:${CMAKE_CURRENT_SOURCE_DIR}/../thirdparty/spdlog>
 )
 
 target_include_directories(ouster_client SYSTEM
diff --git a/ouster-ros/ouster-sdk/ouster_client/src/logging.cpp b/ouster-ros/ouster-sdk/ouster_client/src/logging.cpp
index bf0fc72..09f5077 100644
--- a/ouster-ros/ouster-sdk/ouster_client/src/logging.cpp
+++ b/ouster-ros/ouster-sdk/ouster_client/src/logging.cpp
@@ -1,6 +1,6 @@
 #include "ouster/impl/logging.h"
 
-#include <spdlog/fmt/bundled/args.h>
+#include <fmt/args.h>
 #include <spdlog/sinks/basic_file_sink.h>
 #include <spdlog/sinks/ringbuffer_sink.h>
 #include <spdlog/sinks/rotating_file_sink.h>
