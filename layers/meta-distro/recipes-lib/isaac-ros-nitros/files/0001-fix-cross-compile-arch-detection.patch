Fix cross-compilation issues in isaac_ros_gxf

1. Architecture detection: execute_process(COMMAND uname -m) runs on the build
   host, returning x86_64 even when targeting aarch64. Replace with
   CMAKE_SYSTEM_PROCESSOR, which the OE toolchain file sets correctly.

2. JetPack dir: only gxf_aarch64_cuda_13_0/ exists in this release
   (gxf_jetpack70/ is absent), so select it unconditionally for all aarch64.

3. ament_index_get_resource returns an absolute target path
   (/opt/ros/humble/...) which does not exist on the build host during
   cross-compilation. Prefix with CMAKE_SYSROOT (set to ${RECIPE_SYSROOT} by
   the OE cmake toolchain) so the include resolves to the staged sysroot.

Upstream-Status: Inappropriate [OE-specific]

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 3197738..3d5f9a7 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -21,7 +21,7 @@ project(isaac_ros_gxf)
 # Add option for overriding GXF core library directory
 option(GXF_CORE_LIB_DIR_OVERRIDE "Override path for GXF core library directory" "")
 
-execute_process(COMMAND uname -m COMMAND tr -d '\n' OUTPUT_VARIABLE ARCHITECTURE)
+set(ARCHITECTURE ${CMAKE_SYSTEM_PROCESSOR})
 message( STATUS "Architecture: ${ARCHITECTURE}" )
 
 find_package(ament_cmake_auto REQUIRED)
@@ -43,13 +43,7 @@ if( ${ARCHITECTURE} STREQUAL "x86_64" )
   install(FILES gxf/core/lib/gxf_x86_64_cuda_13_0/multimedia/libgxf_multimedia.so DESTINATION lib)
   install(FILES gxf/core/lib/gxf_x86_64_cuda_13_0/cuda/libgxf_cuda.so DESTINATION lib)
 elseif( ${ARCHITECTURE} STREQUAL "aarch64" )
-  if(CMAKE_DEVICE STREQUAL "sbsa")
-    set(GXF_CORE_LIB_DIR gxf/core/lib/gxf_aarch64_cuda_13_0/)
-  elseif(CMAKE_DEVICE STREQUAL "arm64")
-    set(GXF_CORE_LIB_DIR gxf/core/lib/gxf_jetpack70/)
-  else()
-    message(FATAL_ERROR "Device is not supported.")
-  endif()
+  set(GXF_CORE_LIB_DIR gxf/core/lib/gxf_aarch64_cuda_13_0/)
   install(DIRECTORY ${GXF_CORE_LIB_DIR} DESTINATION share/${PROJECT_NAME}/gxf/lib)
   install(FILES ${GXF_CORE_LIB_DIR}/core/libgxf_core.so DESTINATION lib)
   install(FILES ${GXF_CORE_LIB_DIR}/logger/libgxf_logger.so DESTINATION lib)
@@ -137,6 +131,11 @@ endif()
 
 # Embed versioning information into installed files
 ament_index_get_resource(ISAAC_ROS_COMMON_CMAKE_PATH isaac_ros_common_cmake_path isaac_ros_common)
+if(CMAKE_CROSSCOMPILING)
+  # ament_index_get_resource returns an absolute target path; prefix with
+  # CMAKE_SYSROOT so the include resolves inside the staged recipe sysroot.
+  set(ISAAC_ROS_COMMON_CMAKE_PATH "${CMAKE_SYSROOT}${ISAAC_ROS_COMMON_CMAKE_PATH}")
+endif()
 include("${ISAAC_ROS_COMMON_CMAKE_PATH}/isaac_ros_common-version-info.cmake")
 generate_version_info(${PROJECT_NAME})
 
