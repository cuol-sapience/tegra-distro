 set_target_properties(Core PROPERTIES
   INTERFACE_INCLUDE_DIRECTORIES
-    "$<INSTALL_PREFIX>/share/${PROJECT_NAME}/gxf/include"
+    "${CMAKE_INSTALL_PREFIX}/share/${PROJECT_NAME}/gxf/include"
 )
