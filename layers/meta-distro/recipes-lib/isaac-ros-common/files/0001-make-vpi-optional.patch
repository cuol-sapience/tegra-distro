Make VPI dependency optional

VPI (Vision Programming Interface) is not available on all Jetson targets
(e.g. Orin Nano on JetPack 6.2.2). Make the find_package call quiet and
guard the library target and sources behind a vpi_FOUND check so the cmake
infrastructure (headers, cmake extras, version info) still installs cleanly
without VPI.

Upstream-Status: Inappropriate [OE-specific]

diff --git a/CMakeLists.txt b/CMakeLists.txt
index 95537fd..ced3432 100644
--- a/CMakeLists.txt
+++ b/CMakeLists.txt
@@ -31,7 +31,7 @@ find_package(CUDAToolkit)
 include(${CMAKE_CURRENT_SOURCE_DIR}/cmake/isaac_ros_common-extras.cmake)
 
 # Dependencies
-find_package(vpi REQUIRED)
+find_package(vpi QUIET)
 
 # NVTX
 option(USE_NVTX "Enable NVTX markers for improved profiling (if available)" ON)
@@ -41,12 +41,21 @@ if(USE_NVTX)
     link_libraries("CUDA::nvtx3")
 endif()
 
-# vpi utilities
-ament_auto_add_library(${PROJECT_NAME} SHARED
-  src/cuda_stream.cpp
-  src/qos.cpp
-)
-target_link_libraries(${PROJECT_NAME} vpi CUDA::cudart)
+if(vpi_FOUND)
+  # vpi utilities
+  ament_auto_add_library(${PROJECT_NAME} SHARED
+    src/cuda_stream.cpp
+    src/qos.cpp
+  )
+  target_link_libraries(${PROJECT_NAME} vpi CUDA::cudart)
+else()
+  message(STATUS "VPI not found — building isaac_ros_common without VPI/CUDA stream support")
+  ament_auto_add_library(${PROJECT_NAME} SHARED
+    src/qos.cpp
+  )
+  target_link_libraries(${PROJECT_NAME} CUDA::cudart)
+endif()
+
 
 # Register cmake in install.
 ament_index_register_resource(isaac_ros_common_cmake_path CONTENT
