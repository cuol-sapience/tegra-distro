
/dts-v1/;
/plugin/;


#include <dt-bindings/clock/tegra234-clock.h>
#include <dt-bindings/gpio/tegra234-gpio.h>
#include <dt-bindings/gpio/gpio.h>
#include <dt-bindings/tegra234-p3767-0000-common.h>


#define CAM0_RST    TEGRA234_MAIN_GPIO(H, 3)
#define CAM0_PWDN   TEGRA234_MAIN_GPIO(H, 6)
#define CAM1_RST	TEGRA234_MAIN_GPIO(AC, 1)
#define CAM1_PWDN   TEGRA234_MAIN_GPIO(AC, 0)
#define CAM_I2C_MUX TEGRA234_AON_GPIO(CC, 3)

/ {
    overlay-name = "Dual Arducam AR0234";
    compatible = JETSON_COMPATIBLE_P3768;

    fragment@0 {
        target-path = "/";
        __overlay__ {
            tegra-capture-vi {
                num-channels = <2>;
                ports {
                    #address-cells = <1>;
                    #size-cells = <0>;
                    port@0 {
                        reg = <0>;
                        ar0234_vi_in0: endpoint {
                            port-index = <1>;
                            bus-width = <2>;
                            remote-endpoint = <&ar0234_csi_out0>;
                        };
                    };
                    port@1 {
                        reg = <1>;
                        ar0234_vi_in1: endpoint {
                            port-index = <2>;
                            bus-width = <2>;
                            remote-endpoint = <&ar0234_csi_out1>;
                        };
                    };
                };
            };

            tegra-camera-platform {
                compatible = "nvidia, tegra-camera-platform";
                modules {
                    module0 {
                        badge = "ar0234_front";
                        position = "front";
                        orientation = "0";
                        drivernode0 {
                            pcl_id = "v4l2_sensor";
                            sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/cam_i2cmux/i2c@0/ar0234_a@0c";
                        };
                    };
                    module1 {
                        badge = "ar0234_rear";
                        position = "rear";
                        orientation = "0";
                        drivernode0 {
                            pcl_id = "v4l2_sensor";
                            sysfs-device-tree = "/sys/firmware/devicetree/base/bus@0/cam_i2cmux/i2c@1/ar0234_b@0c";
                        };
                    };
                };
            };

            bus@0 {
                host1x@13e00000 {
                    nvcsi@15a00000 {
                        num-channels = <2>;
                        #address-cells = <1>;
                        #size-cells = <0>;
                        channel@0 {
                            reg = <0>;
                            ports {
                                #address-cells = <1>;
                                #size-cells = <0>;
                                port@0 {
                                    reg = <0>;
                                    ar0234_csi_in0: endpoint@0 {
                                        port-index = <1>;
                                        bus-width = <2>;
                                        remote-endpoint = <&ar0234_out0>;
                                    };
                                };
                                port@1 {
                                    reg = <1>;
                                    ar0234_csi_out0: endpoint@1 {
                                        remote-endpoint = <&ar0234_vi_in0>;
                                    };
                                };
                            };
                        };
                        channel@1 {
                            reg = <1>;
                            ports {
                                #address-cells = <1>;
                                #size-cells = <0>;
                                port@0 {
                                    reg = <0>;
                                    ar0234_csi_in1: endpoint@2 {
                                        port-index = <2>;
                                        bus-width = <2>;
                                        remote-endpoint = <&ar0234_out1>;
                                    };
                                };
                                port@1 {
                                    reg = <1>;
                                    ar0234_csi_out1: endpoint@3 {
                                        remote-endpoint = <&ar0234_vi_in1>;
                                    };
                                };
                            };
                        };
                    };
                };

                i2c@3180000 {
                    clock-frequency = <1000000>;
                };

                cam_i2cmux {
                    status = "okay";
                    compatible = "i2c-mux-gpio";
                    #address-cells = <1>;
                    #size-cells = <0>;
                    mux-gpios = <&gpio_aon CAM_I2C_MUX GPIO_ACTIVE_LOW>;
                    i2c-parent = <&cam_i2c>;
                    i2c@0 {
                        status = "okay";
                        reg = <0>;
                        #address-cells = <1>;
                        #size-cells = <0>;
                        ar0234_a: ar0234_a@0c {
                            compatible = "arducam,arducam-jvar";
                            reg = <0x0c>;
                            status = "okay";
                            channel = "0";
                            sensor_model = "arducam-jvar";
                            devnode = "video0";

                            physical_w = "5.78";
                            physical_h = "3.62";

                            reset-gpios = <&gpio CAM0_PWDN GPIO_ACTIVE_HIGH>;
                            clocks = <&bpmp TEGRA234_CLK_EXTPERIPH1>;
                            clock-names = "extperiph1";
                            clock-frequency = <24000000>;
                            mclk = "extperiph1";
                            use_sensor_mode_id = "true";
                            mode0 {
                                mclk_khz = "24000";
                                num_lanes = "2";
                                tegra_sinterface = "serial_b";
                                phy_mode = "DPHY";
                                discontinuous_clk = "no";
                                dpcm_enable = "false";
                                cil_settletime = "0";
                                lane_polarity = "6";
                                active_w = "1920";
                                active_h = "1200";
                                mode_type = "bayer";
                                pixel_phase = "grbg";
                                csi_pixel_bit_depth = "10";
                                readout_orientation = "90";
                                line_length = "2448";
                                inherent_gain = "1";
                                mclk_multiplier = "9.33";
                                pix_clk_hz = "182400000";
                                gain_factor = "16";
                                min_gain_val = "16";
                                max_gain_val = "170";
                                step_gain_val = "1";
                                default_gain = "16";
                                min_hdr_ratio = "1";
                                max_hdr_ratio = "1";
                                framerate_factor = "1000000";
                                min_framerate = "2000000";
                                max_framerate = "60000000";
                                step_framerate = "1";
                                default_framerate = "30000000";
                                exposure_factor = "1000000";
                                min_exp_time = "13";
                                max_exp_time = "683709";
                                step_exp_time = "1";
                                default_exp_time = "2495";
                                embedded_metadata_height = "0";
                            };
                            mode1 {
                                mclk_khz = "24000";
                                num_lanes = "2";
                                tegra_sinterface = "serial_b";
                                phy_mode = "DPHY";
                                discontinuous_clk = "no";
                                dpcm_enable = "false";
                                cil_settletime = "0";
                                lane_polarity = "6";
                                active_w = "1920";
                                active_h = "1080";
                                mode_type = "bayer";
                                pixel_phase = "grbg";
                                csi_pixel_bit_depth = "10";
                                readout_orientation = "90";
                                line_length = "2448";
                                inherent_gain = "1";
                                mclk_multiplier = "9.33";
                                pix_clk_hz = "182400000";
                                gain_factor = "16";
                                min_gain_val = "16";
                                max_gain_val = "170";
                                step_gain_val = "1";
                                default_gain = "16";
                                min_hdr_ratio = "1";
                                max_hdr_ratio = "1";
                                framerate_factor = "1000000";
                                min_framerate = "2000000";
                                max_framerate = "60000000";
                                step_framerate = "1";
                                default_framerate = "60000000";
                                exposure_factor = "1000000";
                                min_exp_time = "13";
                                max_exp_time = "683709";
                                step_exp_time = "1";
                                default_exp_time = "2495";
                                embedded_metadata_height = "0";
                            };
                            mode2 {
                                mclk_khz = "24000";
                                num_lanes = "2";
                                tegra_sinterface = "serial_b";
                                phy_mode = "DPHY";
                                discontinuous_clk = "no";
                                dpcm_enable = "false";
                                cil_settletime = "0";
                                lane_polarity = "6";
                                active_w = "1280";
                                active_h = "720";
                                mode_type = "bayer";
                                pixel_phase = "grbg";
                                csi_pixel_bit_depth = "10";
                                readout_orientation = "90";
                                line_length = "2448";
                                inherent_gain = "1";
                                mclk_multiplier = "9.33";
                                pix_clk_hz = "250000000";
                                gain_factor = "16";
                                min_gain_val = "16";
                                max_gain_val = "170";
                                step_gain_val = "1";
                                default_gain = "16";
                                min_hdr_ratio = "1";
                                max_hdr_ratio = "1";
                                framerate_factor = "1000000";
                                min_framerate = "2000000";
                                max_framerate = "120000000";
                                step_framerate = "1";
                                default_framerate = "120000000";
                                exposure_factor = "1000000";
                                min_exp_time = "13";
                                max_exp_time = "683709";
                                step_exp_time = "1";
                                default_exp_time = "2495";
                                embedded_metadata_height = "0";
                            };

                            ports {
                                #address-cells = <1>;
                                #size-cells = <0>;
                                port@0 {
                                    reg = <0>;
                                    ar0234_out0: endpoint {
                                        port-index = <1>;
                                        remote-endpoint = <&ar0234_csi_in0>;
                                        bus-width = <2>;
                                    };
                                };
                            };
                        };
                    };
                    i2c@1 {
                        status = "okay";
                        reg = <1>;
                        #address-cells = <1>;
                        #size-cells = <0>;
                        ar0234_b: ar0234_b@0c {
                            compatible = "arducam,arducam-jvar";
                            reg = <0x0c>;
                            status = "okay";
                            channel = "1";
                            sensor_model = "arducam-jvar";
                            devnode = "video1";

                            physical_w = "3.680";
                            physical_h = "2.760";

                            reset-gpios = <&gpio CAM1_PWDN GPIO_ACTIVE_HIGH>;
                            clocks = <&bpmp TEGRA234_CLK_EXTPERIPH1>;
                            clock-names = "extperiph1";
                            clock-frequency = <24000000>;
                            mclk = "extperiph1";
                            use_sensor_mode_id = "true";
                            mode0 {
                                mclk_khz = "24000";
                                num_lanes = "2";
                                tegra_sinterface = "serial_c";
                                phy_mode = "DPHY";
                                discontinuous_clk = "no";
                                dpcm_enable = "false";
                                cil_settletime = "0";
                                lane_polarity = "0";
                                active_w = "1920";
                                active_h = "1200";
                                mode_type = "bayer";
                                pixel_phase = "grbg";
                                csi_pixel_bit_depth = "10";
                                readout_orientation = "90";
                                line_length = "2448";
                                inherent_gain = "1";
                                mclk_multiplier = "9.33";
                                pix_clk_hz = "182400000";
                                gain_factor = "16";
                                min_gain_val = "16";
                                max_gain_val = "170";
                                step_gain_val = "1";
                                default_gain = "16";
                                min_hdr_ratio = "1";
                                max_hdr_ratio = "1";
                                framerate_factor = "1000000";
                                min_framerate = "2000000";
                                max_framerate = "60000000";
                                step_framerate = "1";
                                default_framerate = "30000000";
                                exposure_factor = "1000000";
                                min_exp_time = "13";
                                max_exp_time = "683709";
                                step_exp_time = "1";
                                default_exp_time = "2495";
                                embedded_metadata_height = "0";
                            };
                            mode1 {
                                mclk_khz = "24000";
                                num_lanes = "2";
                                tegra_sinterface = "serial_c";
                                phy_mode = "DPHY";
                                discontinuous_clk = "no";
                                dpcm_enable = "false";
                                cil_settletime = "0";
                                lane_polarity = "0";
                                active_w = "1920";
                                active_h = "1080";
                                mode_type = "bayer";
                                pixel_phase = "grbg";
                                csi_pixel_bit_depth = "10";
                                readout_orientation = "90";
                                line_length = "2448";
                                inherent_gain = "1";
                                mclk_multiplier = "9.33";
                                pix_clk_hz = "182400000";
                                gain_factor = "16";
                                min_gain_val = "16";
                                max_gain_val = "170";
                                step_gain_val = "1";
                                default_gain = "16";
                                min_hdr_ratio = "1";
                                max_hdr_ratio = "1";
                                framerate_factor = "1000000";
                                min_framerate = "2000000";
                                max_framerate = "60000000";
                                step_framerate = "1";
                                default_framerate = "60000000";
                                exposure_factor = "1000000";
                                min_exp_time = "13";
                                max_exp_time = "683709";
                                step_exp_time = "1";
                                default_exp_time = "2495";
                                embedded_metadata_height = "0";
                            };
                            mode2 {
                                mclk_khz = "24000";
                                num_lanes = "2";
                                tegra_sinterface = "serial_c";
                                phy_mode = "DPHY";
                                discontinuous_clk = "no";
                                dpcm_enable = "false";
                                cil_settletime = "0";
                                lane_polarity = "0";
                                active_w = "1280";
                                active_h = "720";
                                mode_type = "bayer";
                                pixel_phase = "grbg";
                                csi_pixel_bit_depth = "10";
                                readout_orientation = "90";
                                line_length = "2448";
                                inherent_gain = "1";
                                mclk_multiplier = "9.33";
                                pix_clk_hz = "250000000";
                                gain_factor = "16";
                                min_gain_val = "16";
                                max_gain_val = "170";
                                step_gain_val = "1";
                                default_gain = "16";
                                min_hdr_ratio = "1";
                                max_hdr_ratio = "1";
                                framerate_factor = "1000000";
                                min_framerate = "2000000";
                                max_framerate = "120000000";
                                step_framerate = "1";
                                default_framerate = "120000000";
                                exposure_factor = "1000000";
                                min_exp_time = "13";
                                max_exp_time = "683709";
                                step_exp_time = "1";
                                default_exp_time = "2495";
                                embedded_metadata_height = "0";
                            };
                            ports {
                                #address-cells = <1>;
                                #size-cells = <0>;
                                port@0 {
                                    reg = <0>;
                                    ar0234_out1: endpoint {
                                        port-index = <2>;
                                        remote-endpoint = <&ar0234_csi_in1>;
                                        bus-width = <2>;
                                    };
                                };
                            };
                        };
                    };
                };
            };
        };
    };
};
