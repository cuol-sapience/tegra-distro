KERNEL=="nvmap", MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"

# card0 = nv_platform (nvdisplay scanout) — seat master
SUBSYSTEM=="drm", KERNEL=="card0", \
    ENV{ID_SEAT}="seat0", \
    TAG+="master-of-seat", TAG+="seat", TAG+="uaccess", \
    MODE="0660", GROUP="video"

# card1 = host1x DRM — must explicitly assign to seat0 (non-PCI, no auto-assign)
SUBSYSTEM=="drm", KERNEL=="card1", \
    ENV{ID_SEAT}="seat0", \
    TAG+="seat", TAG+="uaccess", \
    MODE="0660", GROUP="video"

# Render nodes — MODE 0666 for ephemeral GDM greeter users (not in video group)
# nvidia EGL internally opens renderD* even when given a card fd
SUBSYSTEM=="drm", KERNEL=="renderD*", \
    TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0", \
    MODE="0666", GROUP="video"

# nvidia-gpu-v2 (Orin) — GPU command submission for EGL, X, CUDA
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="as",       MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="channel",  MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="ctrl",     MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="tsg",      MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="ctxsw",    MODE="0660", GROUP="video", TAG+="uaccess"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="dbg",      MODE="0660", GROUP="video", TAG+="uaccess"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="prof",     MODE="0660", GROUP="video", TAG+="uaccess"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="prof-ctx", MODE="0660", GROUP="video", TAG+="uaccess"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="prof-dev", MODE="0660", GROUP="video", TAG+="uaccess"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="sched",    MODE="0660", GROUP="video", TAG+="uaccess"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="nvsched",  MODE="0660", GROUP="video", TAG+="uaccess"
SUBSYSTEM=="nvidia-gpu-v2", KERNEL=="nvsched_ctrl_fifo", MODE="0660", GROUP="video", TAG+="uaccess"
SUBSYSTEM=="nvidia-gpu-v2-power", KERNEL=="power", MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"

# nvidia-gpu-v2 (PCI variant, future-proofing)
SUBSYSTEM=="nvidia-pci-gpu-v2", KERNEL=="as",       MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
SUBSYSTEM=="nvidia-pci-gpu-v2", KERNEL=="channel",  MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
SUBSYSTEM=="nvidia-pci-gpu-v2", KERNEL=="ctrl",     MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
SUBSYSTEM=="nvidia-pci-gpu-v2", KERNEL=="tsg",      MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
SUBSYSTEM=="nvidia-pci-gpu-v2-power", KERNEL=="power", MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"

# nvhost-*-gpu — actual /dev nodes for GPU command submission (both Xavier and Orin)
# On Orin these are separate from nvidia-gpu-v2 sysfs devices but share major 502
# Critical devices need MODE=0666 for ephemeral GDM greeter users (not in video group)
KERNEL=="nvhost-gpu",              MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
KERNEL=="nvhost-as-gpu",           MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
KERNEL=="nvhost-ctrl-gpu",         MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
KERNEL=="nvhost-tsg-gpu",          MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"
KERNEL=="nvhost-ctxsw-gpu",        MODE="0666", GROUP="video", TAG+="uaccess"
KERNEL=="nvhost-dbg-gpu",          MODE="0666", GROUP="video", TAG+="uaccess"
KERNEL=="nvhost-prof-gpu",         MODE="0666", GROUP="video", TAG+="uaccess"
KERNEL=="nvhost-prof-ctx-gpu",     MODE="0666", GROUP="video", TAG+="uaccess"
KERNEL=="nvhost-prof-dev-gpu",     MODE="0666", GROUP="video", TAG+="uaccess"
KERNEL=="nvhost-sched-gpu",        MODE="0660", GROUP="video", TAG+="uaccess"
KERNEL=="nvhost-nvsched-gpu",      MODE="0660", GROUP="video", TAG+="uaccess"
KERNEL=="nvhost-nvsched_ctrl_fifo-gpu", MODE="0660", GROUP="video", TAG+="uaccess"
KERNEL=="nvhost-power-gpu",        MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"

# host1x subsystem (fence/sync infrastructure)
SUBSYSTEM=="host1x", MODE="0666", GROUP="video", TAG+="seat", TAG+="uaccess", ENV{ID_SEAT}="seat0"

# NvSciIPC and hwpm (needed by some NVIDIA user-space components)
KERNEL=="nvsciipc",                MODE="0660", GROUP="video"
KERNEL=="tegra-soc-hwpm",          MODE="0660", GROUP="video"


